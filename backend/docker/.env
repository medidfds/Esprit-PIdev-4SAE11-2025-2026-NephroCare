# NephroCare Environment Configuration
# Copy this file to .env and update with your values

# ==================== INFRASTRUCTURE ====================

# MySQL
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=nephrocare_db
MYSQL_USER=nephrocare
MYSQL_PASSWORD=nephrocare_pass

# RabbitMQ
RABBITMQ_DEFAULT_USER=nephrocare
RABBITMQ_DEFAULT_PASS=nephrocare_pass

# Keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# ==================== PORTS (Host) ====================

# Infrastructure
MYSQL_PORT=3306
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# Backend Services
CONFIG_PORT=8888
DISCOVERY_PORT=8761
GATEWAY_PORT=8075
USER_SERVICE_PORT=8081
CLINICAL_SERVICE_PORT=8082
DIALYSIS_SERVICE_PORT=8083
DIALYSIS_TRANSPORT_PORT=8085
PHARMACY_SERVICE_PORT=8086
MONITORING_SERVICE_PORT=8799
HOSPITALIZATION_PORT=8070
ORDER_SERVICE_PORT=8090
DIAGNOSTIC_SERVICE_PORT=8091

# Frontend
FRONTEND_BACK_PORT=4200
FRONTEND_FRONT_PORT=4201

# Node.js Services
PDF_GENERATOR_PORT=4000
COMMUNICATION_PORT=3000
